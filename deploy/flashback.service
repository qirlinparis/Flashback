[Unit]
Description=Flashback API Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/flashback
EnvironmentFile=/opt/flashback/.env
ExecStart=/usr/bin/python3 -m src.api
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
