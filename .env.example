# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# Get from openrouter.ai
OPENROUTER_API_KEY=your_key_here

# API server (defaults shown)
API_HOST=0.0.0.0
API_PORT=8000

# LLM model via OpenRouter (default shown)
LLM_MODEL=anthropic/claude-sonnet-4

# Secret salt for API token hashing
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN_SECRET=your_secret_here

# Override database path — for local testing only, do not set in production
# DB_PATH=test.db
